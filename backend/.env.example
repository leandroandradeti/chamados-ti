# Refresh Token
JWT_REFRESH_SECRET=sua-chave-refresh-super-segura-aqui
JWT_REFRESH_EXPIRES_IN=7d
# Servidor
NODE_ENV=development
PORT=3001
API_VERSION=v1
START_RUN_BOOTSTRAP=true
ENFORCE_HTTPS=false
TRUST_PROXY=loopback
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000

# Banco de Dados
# Preferencial em cloud (Neon/Vercel): use DATABASE_URL
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chamados_ti
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_MIN_CLOUD=1
DB_POOL_ACQUIRE_MS=60000
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Admin inicial (seed)
# Configure explicitamente antes do primeiro bootstrap. Nenhuma senha padrão é criada.
DEFAULT_ADMIN_EMAIL=configure-o-email-admin@empresa.com.br
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NOME=Administrador
RESET_ADMIN_PASSWORD_ON_SEED=false
MIN_ADMIN_PASSWORD_LENGTH=12

# JWT
JWT_SECRET=sua-chave-secreta-super-segura-aqui
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha
SMTP_FROM=noreply@chamados-ti.com

# Configurações Gerais
TIMEZONE=America/Sao_Paulo
MULTIEMPRESA=false
SOFT_DELETE=true
AUDITORIA=true

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Logs
LOG_LEVEL=info
LOG_FILE=logs/app.log
